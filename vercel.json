{
    "version": 2,
    "builds": [
        {
            "src": "promptdeck/wsgi.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "promptdeck/wsgi.py"
        }
    ],
    "buildCommand": "python manage.py collectstatic --noinput"
}